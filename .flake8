[flake8]
max-line-length = 120
# W503: line break before binary operator — conflicts with black formatter
# E203: whitespace before ':' — conflicts with black slice formatting
# Both are documented black incompatibilities:
# https://black.readthedocs.io/en/stable/guides/using_black_with_other_tools.html#flake8
extend-ignore = W503, E203
per-file-ignores =
    tests/*:E402,F811,E501

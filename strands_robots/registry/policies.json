{
  "providers": {
    "mock": {
      "module": "strands_robots.policies",
      "class": "MockPolicy",
      "description": "Sinusoidal test actions (no deps)",
      "requires": [],
      "config_keys": [],
      "defaults": {}
    },
    "groot": {
      "module": "strands_robots.policies.groot",
      "class": "Gr00tPolicy",
      "description": "NVIDIA GR00T N1.5/N1.6 via ZMQ",
      "requires": ["port"],
      "config_keys": ["port", "host", "data_config"],
      "defaults": {"host": "localhost"}
    },
    "lerobot_async": {
      "module": "strands_robots.policies.lerobot_async",
      "class": "LerobotAsyncPolicy",
      "description": "LeRobot gRPC async inference (ACT, Pi0, SmolVLA, ...)",
      "requires": ["server_address"],
      "config_keys": ["server_address", "policy_type", "pretrained_name_or_path", "actions_per_chunk", "device", "fps", "task", "lerobot_features", "rename_map"],
      "defaults": {}
    },
    "lerobot_local": {
      "module": "strands_robots.policies.lerobot_local",
      "class": "LerobotLocalPolicy",
      "description": "Direct HuggingFace inference (no server)",
      "requires": [],
      "config_keys": ["pretrained_name_or_path", "policy_type", "device", "actions_per_step"],
      "defaults": {}
    },
    "dreamgen": {
      "module": "strands_robots.policies.dreamgen",
      "class": "DreamgenPolicy",
      "description": "GR00T-Dreams IDM + VLA pipeline",
      "requires": ["model_path"],
      "config_keys": ["model_path", "mode", "embodiment_tag", "modality_config", "modality_transform", "device", "action_horizon", "action_dim", "denoising_steps"],
      "defaults": {}
    },
    "dreamzero": {
      "module": "strands_robots.policies.dreamzero",
      "class": "DreamzeroPolicy",
      "description": "DreamZero world action model (WebSocket)",
      "requires": [],
      "config_keys": ["host", "port"],
      "defaults": {"host": "localhost", "port": 8000}
    },
    "cosmos_predict": {
      "module": "strands_robots.policies.cosmos_predict",
      "class": "CosmosPredictPolicy",
      "description": "NVIDIA Cosmos world model policy",
      "requires": [],
      "config_keys": ["pretrained_name_or_path"],
      "defaults": {}
    },
    "gear_sonic": {
      "module": "strands_robots.policies.gear_sonic",
      "class": "GearSonicPolicy",
      "description": "GEAR-SONIC humanoid controller (135Hz ONNX)",
      "requires": [],
      "config_keys": [],
      "defaults": {}
    }
  },
  "aliases": {
    "lerobot": "lerobot_local",
    "dream_zero": "dreamzero",
    "world_action_model": "dreamzero",
    "cosmos": "cosmos_predict",
    "cosmos_predict2": "cosmos_predict",
    "cosmos_predict_2b": "cosmos_predict",
    "cosmos_predict_14b": "cosmos_predict",
    "cosmos_policy": "cosmos_predict",
    "cosmos_world_model": "cosmos_predict",
    "nvidia_cosmos": "cosmos_predict",
    "sonic": "gear_sonic",
    "gear": "gear_sonic",
    "humanoid_sonic": "gear_sonic"
  },
  "resolver": {
    "hf_org_map": {
      "lerobot": "lerobot_local",
      "nvidia": "groot",
      "dream-org": "dreamgen",
      "gear-dreams": "dreamzero",
      "gear-group": "gear_sonic"
    },
    "model_id_overrides": {
      "nvidia/gr00t": "groot",
      "nvidia/groot": "groot",
      "nvidia/dreamzero": "dreamzero",
      "nvidia/cosmos-predict": "cosmos_predict",
      "nvidia/cosmos-predict2": "cosmos_predict",
      "nvidia/cosmos-predict2.5-2b": "cosmos_predict",
      "nvidia/cosmos-predict2.5-14b": "cosmos_predict",
      "nvidia/cosmos-policy": "cosmos_predict"
    },
    "shorthands": {
      "mock": "mock",
      "random": "mock",
      "test": "mock",
      "groot": "groot",
      "dreamgen": "dreamgen",
      "dreamzero": "dreamzero",
      "cosmos": "cosmos_predict",
      "cosmos_predict": "cosmos_predict",
      "gear_sonic": "gear_sonic"
    },
    "url_patterns": {
      "^wss?://": "dreamzero",
      "^zmq://": "groot",
      "^grpc://": "lerobot_async",
      "^[\\w.\\-]+:\\d+$": "lerobot_async"
    }
  }
}

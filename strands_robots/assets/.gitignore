# Robot model assets — downloaded on-the-fly to ~/.strands_robots/assets/
#
# The pip package ships ONLY XML model files (lightweight).
# Mesh files (STL, OBJ) are downloaded automatically when needed via:
#   python -m strands_robots.tools.download_assets
#
# Sources:
#   - MuJoCo Menagerie: https://github.com/google-deepmind/mujoco_menagerie
#   - Custom repos: defined per-robot in registry/robots.json (asset.source)

# Exclude ALL mesh/binary files (large — downloaded to user cache)
**/*.stl
**/*.STL
**/*.obj
**/*.OBJ
**/*.msh
**/*.MSH

# Exclude textures
**/*.png
**/*.jpg
**/*.jpeg

# Exclude menagerie extras
**/README.md
**/LICENSE
**/CHANGELOG.md

# Keep only Python + XML files
!__init__.py
!download.py
!.gitignore
!**/*.xml

<!-- OpenArm Scene: Table-mounted arm with ground plane and objects -->
<mujoco model="openarm_scene">
  <include file="openarm.xml"/>

  <statistic center="0 0 0.4" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <worldbody>
    <!-- Ground -->
    <geom name="ground" type="plane" size="2 2 0.01" material="groundplane" pos="0 0 -0.001"/>

    <!-- Table -->
    <body name="table" pos="0 0 -0.05">
      <geom name="table_top" type="box" size="0.4 0.4 0.05" rgba="0.5 0.35 0.2 1"
            mass="20" friction="1 0.005 0.0001"/>
      <geom name="table_leg1" type="cylinder" size="0.03 0.4" pos="0.35 0.35 -0.45" rgba="0.4 0.4 0.4 1"/>
      <geom name="table_leg2" type="cylinder" size="0.03 0.4" pos="-0.35 0.35 -0.45" rgba="0.4 0.4 0.4 1"/>
      <geom name="table_leg3" type="cylinder" size="0.03 0.4" pos="0.35 -0.35 -0.45" rgba="0.4 0.4 0.4 1"/>
      <geom name="table_leg4" type="cylinder" size="0.03 0.4" pos="-0.35 -0.35 -0.45" rgba="0.4 0.4 0.4 1"/>
    </body>

    <!-- Manipulation objects -->
    <body name="cube" pos="0.3 0 0.05">
      <freejoint name="cube_joint"/>
      <geom name="cube_geom" type="box" size="0.02 0.02 0.02" rgba="0.8 0.2 0.2 1" mass="0.05"
            friction="1 0.005 0.0001" solref="0.01 1"/>
    </body>
  </worldbody>
</mujoco>

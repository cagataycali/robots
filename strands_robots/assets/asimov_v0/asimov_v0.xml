    <!-- 12 actuated motor joints (6 per leg). Toe joints are passive springs. -->
    <actuator>
        <position name="left_hip_pitch"    joint="left_hip_pitch_joint"    kp="200" kv="10" forcerange="-120 120" inheritrange="1"/>
        <position name="left_hip_roll"     joint="left_hip_roll_joint"     kp="200" kv="10" forcerange="-90 90"   inheritrange="1"/>
        <position name="left_hip_yaw"      joint="left_hip_yaw_joint"     kp="150" kv="8"  forcerange="-60 60"   inheritrange="1"/>
        <position name="left_knee"         joint="left_knee_joint"        kp="200" kv="10" forcerange="-75 75"   inheritrange="1"/>
        <position name="left_ankle_pitch"  joint="left_ankle_pitch_joint" kp="80"  kv="5"  forcerange="-36 36"   inheritrange="1"/>
        <position name="left_ankle_roll"   joint="left_ankle_roll_joint"  kp="80"  kv="5"  forcerange="-36 36"   inheritrange="1"/>
        <position name="right_hip_pitch"   joint="right_hip_pitch_joint"  kp="200" kv="10" forcerange="-120 120" inheritrange="1"/>
        <position name="right_hip_roll"    joint="right_hip_roll_joint"   kp="200" kv="10" forcerange="-90 90"   inheritrange="1"/>
        <position name="right_hip_yaw"     joint="right_hip_yaw_joint"    kp="150" kv="8"  forcerange="-60 60"   inheritrange="1"/>
        <position name="right_knee"        joint="right_knee_joint"       kp="200" kv="10" forcerange="-75 75"   inheritrange="1"/>
        <position name="right_ankle_pitch" joint="right_ankle_pitch_joint" kp="80" kv="5"  forcerange="-36 36"   inheritrange="1"/>
        <position name="right_ankle_roll"  joint="right_ankle_roll_joint" kp="80"  kv="5"  forcerange="-36 36"   inheritrange="1"/>
    </actuator>

    <contact>
        <exclude body1="pelvis_link" body2="left_hip_pitch_link"/>
        <exclude body1="left_hip_pitch_link" body2="left_hip_roll_link"/>
        <exclude body1="left_hip_roll_link" body2="left_hip_yaw_link"/>
        <exclude body1="left_hip_yaw_link" body2="left_knee_link"/>
        <exclude body1="left_knee_link" body2="left_ankle_pitch_link"/>
        <exclude body1="left_ankle_pitch_link" body2="left_ankle_roll_link"/>
        <exclude body1="left_ankle_roll_link" body2="left_toe_link"/>
        <exclude body1="pelvis_link" body2="right_hip_pitch_link"/>
        <exclude body1="right_hip_pitch_link" body2="right_hip_roll_link"/>
        <exclude body1="right_hip_roll_link" body2="right_hip_yaw_link"/>
        <exclude body1="right_hip_yaw_link" body2="right_knee_link"/>
        <exclude body1="right_knee_link" body2="right_ankle_pitch_link"/>
        <exclude body1="right_ankle_pitch_link" body2="right_ankle_roll_link"/>
        <exclude body1="right_ankle_roll_link" body2="right_toe_link"/>
    </contact>

    <sensor>
        <gyro name="imu_ang_vel" site="imu_in_pelvis"/>
        <velocimeter name="imu_lin_vel" site="imu_in_pelvis"/>
        <framequat name="imu_quat" objtype="site" objname="imu_in_pelvis"/>
        <subtreeangmom name="root_angmom" body="pelvis_link"/>
    </sensor>
</mujoco>

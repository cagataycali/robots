<mujoco model="asimov_v0">
    <compiler angle="radian" meshdir="assets/meshes"/>

    <default>
        <joint frictionloss="0"/>

        <default class="motor">
            <joint damping="0"/>
        </default>

        <default class="visual">
            <geom material="visual_grey" contype="0" conaffinity="0" group="2"/>
        </default>

        <default class="collision">
            <geom group="3" rgba=".2 .6 .2 .3" type="capsule" contype="1" conaffinity="1"/>
            <default class="foot_capsule">
                <geom type="capsule" size="0.01"/>
            </default>
            <default class="body_capsule">
